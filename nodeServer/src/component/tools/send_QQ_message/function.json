  "function": {
    "name": "send_QQ_message",
    "description": "向指定QQ号发送消息，支持文本、图片、语音的混合消息。消息格式：使用@br分隔不同消息段，%[文件路径]表示文件（图片或语音）",
    "parameters": {
      "type": "object",
      "properties": {
        "send_text": {"type": "string", "description": "要发送的消息内容，如\"你好啊@br%[C:/example.png]@br这样图片怎么样@br%[C:/example.wav]\""},
        "aim_qq_num": {"type": "string", "description": "目标QQ号"}
      },
      "required": ["send_text", "aim_qq_num"]
    }
  }
},
